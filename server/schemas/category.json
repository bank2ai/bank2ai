{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bank2ai.org/schemas/category.json",
  "title": "Category",
  "description": "Transaction category for spending classification",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique category identifier"
    },
    "name": {
      "type": "string",
      "description": "Category name (localized)",
      "examples": ["Groceries", "Transportation", "Entertainment", "Utilities"]
    }
  },
  "required": ["id", "name"]
}

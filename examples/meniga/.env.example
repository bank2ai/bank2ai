# Bank adapter to use. Options: "demo", "meniga", or a fully qualified "module.ClassName" path.
BANK2AI_ADAPTER=demo

# Logging
BANK2AI_LOG_RESPONSES=true
BANK2AI_LOG_LEVEL=DEBUG

# Meniga adapter config (only required when BANK2AI_ADAPTER=meniga)
BANK2AI_MENIGA_BASE_URL=https://api.meniga.cloud/user/core
BANK2AI_MENIGA_EMAIL=your-email@example.com
BANK2AI_MENIGA_PASSWORD=your-password
